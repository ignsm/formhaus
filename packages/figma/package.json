{
  "name": "@formhaus/figma",
  "version": "0.3.1",
  "description": "Figma plugin: generates form mockups from @formhaus/core form definitions",
  "scripts": {
    "build": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es2017 --format=iife",
    "watch": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es2017 --format=iife --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@formhaus/core": "workspace:*"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "esbuild": "^0.25.0",
    "vitest": "^4.1.3",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ignsm/formhaus.git",
    "directory": "packages/figma"
  }
}
