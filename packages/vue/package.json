{
  "name": "@formhaus/vue",
  "version": "0.3.1",
  "description": "Vue 3 components for Formhaus forms. Define a form once in JSON, render with native HTML or your own components.",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@formhaus/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.3",
    "vite": "^6.2.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.3",
    "vue": "^3.5.13"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ignsm/formhaus.git",
    "directory": "packages/vue"
  }
}
