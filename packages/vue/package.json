{
  "name": "@formhaus/vue",
  "version": "0.2.0",
  "description": "Vue 3 components for formhaus JSON-schema-driven forms",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
