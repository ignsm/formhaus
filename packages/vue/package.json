  },
  "dependencies": {
    "@formhaus/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "vue": "^3.5.13",
    "vue-tsc": "^2.0.0",
    "vite": "^6.2.2",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ignsm/formhaus.git",
    "directory": "packages/vue"
  }
